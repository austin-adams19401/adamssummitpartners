---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  transparentHeader?: boolean;
}

const {
  title = 'Adams Summit Partners',
  description = 'Adams Summit Partners is a Utah-based real estate firm acquiring and operating multifamily properties across the Mountain West.',
  image = '/images/logo.png',
  transparentHeader = false,
} = Astro.props;

const fullTitle = title === 'Adams Summit Partners' ? title : `${title} | Adams Summit Partners`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Adams Summit Partners',
  url: Astro.site?.toString(),
  logo: new URL('/images/logo.png', Astro.site).toString(),
  founder: { '@type': 'Person', name: 'Austin Adams' },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Kaysville',
    addressRegion: 'UT',
    addressCountry: 'US',
  },
  email: 'invest@adamssummitpartners.com',
  areaServed: 'Mountain West United States',
  description:
    'Real estate firm acquiring and operating multifamily properties in the Mountain West for working investors.',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Adams Summit Partners" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header transparent={transparentHeader} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
