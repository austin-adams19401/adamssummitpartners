---
interface Props {
  eyebrow?: string;
  heading?: string;
  tagline?: string;
  body?: string;
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  backgroundImage?: string;
}

const {
  eyebrow = 'Mountain West Multifamily',
  heading = 'Adams Summit Partners',
  tagline = 'Elevating Value. Building Legacy.',
  body = 'A Utah-based real estate firm acquiring and operating multifamily properties across the Mountain West. Built for investors who want the operator to pick up the phone.',
  primaryCtaLabel = 'View Opportunities',
  primaryCtaHref = '/portfolio',
  secondaryCtaLabel = 'Our Approach',
  secondaryCtaHref = '/approach',
  backgroundImage = 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=2400&q=60',
} = Astro.props;
---

<section
  class="relative -mt-[72px] md:-mt-[80px] min-h-[100svh] flex items-center text-white overflow-hidden"
>
  <div class="absolute inset-0 bg-navy">
    <img
      src={backgroundImage}
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover opacity-30"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-navy/80 via-navy/60 to-navy"></div>
  </div>

  <div class="relative container-narrow pt-32 pb-24 md:pt-40 md:pb-32 w-full">
    <div class="max-w-3xl">
      <p class="eyebrow mb-6">{eyebrow}</p>
      <h1 class="font-serif text-white text-5xl sm:text-6xl md:text-7xl leading-[1.05] mb-6">
        {heading}
      </h1>
      <div class="flex items-center gap-4 mb-8">
        <span class="gold-rule"></span>
        <span class="font-serif italic text-gold text-lg md:text-xl tracking-wide">{tagline}</span>
      </div>
      <p class="text-lg md:text-xl text-white/80 leading-relaxed max-w-2xl mb-10">
        {body}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href={primaryCtaHref} class="btn-primary">{primaryCtaLabel}</a>
        <a href={secondaryCtaHref} class="btn-outline">{secondaryCtaLabel}</a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/60 hidden md:block" aria-hidden="true">
    <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
