---
// Netlify-native form. On Netlify, submissions are captured automatically
// when the form is detected at build time. Honeypot prevents most spam.
---

<form
  name="investor-inquiry"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="space-y-6"
>
  <input type="hidden" name="form-name" value="investor-inquiry" />
  <p class="hidden">
    <label>Don't fill this out if you're human: <input name="bot-field" /></label>
  </p>

  <div class="grid gap-6 md:grid-cols-2">
    <label class="block">
      <span class="block text-xs tracking-widest uppercase text-charcoal/70 font-medium mb-2">
        Full Name
      </span>
      <input
        type="text"
        name="name"
        required
        autocomplete="name"
        class="w-full px-4 py-3 bg-white border border-navy/20 focus:border-gold focus:outline-none focus:ring-1 focus:ring-gold text-charcoal"
      />
    </label>

    <label class="block">
      <span class="block text-xs tracking-widest uppercase text-charcoal/70 font-medium mb-2">
        Email
      </span>
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        class="w-full px-4 py-3 bg-white border border-navy/20 focus:border-gold focus:outline-none focus:ring-1 focus:ring-gold text-charcoal"
      />
    </label>

    <label class="block">
      <span class="block text-xs tracking-widest uppercase text-charcoal/70 font-medium mb-2">
        Phone
      </span>
      <input
        type="tel"
        name="phone"
        autocomplete="tel"
        class="w-full px-4 py-3 bg-white border border-navy/20 focus:border-gold focus:outline-none focus:ring-1 focus:ring-gold text-charcoal"
      />
    </label>

    <label class="block">
      <span class="block text-xs tracking-widest uppercase text-charcoal/70 font-medium mb-2">
        Accredited Investor?
      </span>
      <select
        name="accredited"
        class="w-full px-4 py-3 bg-white border border-navy/20 focus:border-gold focus:outline-none focus:ring-1 focus:ring-gold text-charcoal"
      >
        <option value="">Select...</option>
        <option value="yes">Yes</option>
        <option value="no">No</option>
        <option value="unsure">Not sure</option>
      </select>
    </label>
  </div>

  <label class="block">
    <span class="block text-xs tracking-widest uppercase text-charcoal/70 font-medium mb-2">
      Investment Range
    </span>
    <select
      name="investment-range"
      class="w-full px-4 py-3 bg-white border border-navy/20 focus:border-gold focus:outline-none focus:ring-1 focus:ring-gold text-charcoal"
    >
      <option value="">Select...</option>
      <option value="under-50k">Under $50K</option>
      <option value="50k-100k">$50K – $100K</option>
      <option value="100k-250k">$100K – $250K</option>
      <option value="250k-500k">$250K – $500K</option>
      <option value="500k-plus">$500K+</option>
    </select>
  </label>

  <label class="block">
    <span class="block text-xs tracking-widest uppercase text-charcoal/70 font-medium mb-2">
      How can we help?
    </span>
    <textarea
      name="message"
      rows="5"
      class="w-full px-4 py-3 bg-white border border-navy/20 focus:border-gold focus:outline-none focus:ring-1 focus:ring-gold text-charcoal resize-y"
    ></textarea>
  </label>

  <div class="pt-2">
    <button type="submit" class="btn-primary">Submit Inquiry</button>
  </div>

  <p class="text-xs text-charcoal/60 leading-relaxed">
    By submitting this form you agree to be contacted by Adams Summit Partners regarding investment
    opportunities. Your information will not be shared with third parties. Submitting this form does
    not create an investor relationship.
  </p>
</form>
