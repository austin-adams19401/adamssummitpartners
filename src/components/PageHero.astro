---
interface Props {
  eyebrow?: string;
  heading: string;
  lede?: string;
}

const { eyebrow, heading, lede } = Astro.props;
---

<section class="bg-navy text-white">
  <div class="container-narrow py-24 md:py-32">
    {eyebrow && <p class="eyebrow mb-5">{eyebrow}</p>}
    <h1 class="font-serif text-5xl md:text-6xl text-white leading-tight mb-6 max-w-3xl">
      {heading}
    </h1>
    <span class="gold-rule mb-6"></span>
    {
      lede && (
        <p class="text-lg md:text-xl text-white/80 leading-relaxed max-w-2xl">{lede}</p>
      )
    }
  </div>
</section>
