---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
  invert?: boolean;
}

const { stats, invert = false } = Astro.props;
---

<dl
  class:list={[
    'grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12',
  ]}
>
  {
    stats.map(({ value, label }) => (
      <div class="text-center">
        <dt class="font-serif text-5xl md:text-6xl text-gold mb-2">{value}</dt>
        <dd
          class:list={[
            'text-xs tracking-widest uppercase font-medium',
            invert ? 'text-white/70' : 'text-charcoal/70',
          ]}
        >
          {label}
        </dd>
      </div>
    ))
  }
</dl>
