---
interface Props {
  name: string;
  location: string;
  assetClass: string;
  units?: number | string;
  status: 'Active' | 'Exited' | 'Coming Soon' | 'Sample';
  image: string;
  summary?: string;
  href?: string;
}

const { name, location, assetClass, units, status, image, summary, href } = Astro.props;

const statusStyles: Record<string, string> = {
  Active: 'bg-gold text-navy',
  Exited: 'bg-white/90 text-navy',
  'Coming Soon': 'bg-navy text-gold border border-gold',
  Sample: 'bg-charcoal/80 text-white',
};

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group block bg-white overflow-hidden shadow-sm transition-shadow',
    href ? 'hover:shadow-xl' : '',
  ]}
>
  <div class="relative aspect-[4/3] overflow-hidden bg-navy/10">
    <img
      src={image}
      alt={name}
      loading="lazy"
      class:list={[
        'w-full h-full object-cover transition-transform duration-700',
        href ? 'group-hover:scale-105' : '',
      ]}
    />
    <span
      class:list={[
        'absolute top-4 left-4 px-3 py-1 text-[10px] tracking-widest uppercase font-medium',
        statusStyles[status] ?? statusStyles.Sample,
      ]}
    >
      {status}
    </span>
  </div>

  <div class="p-6 md:p-7">
    <p class="eyebrow mb-2">{assetClass}</p>
    <h3 class="font-serif text-2xl text-navy mb-1">{name}</h3>
    <p class="text-sm text-charcoal/70">{location}</p>

    {
      (units || summary) && (
        <div class="mt-4 pt-4 border-t border-navy/10 text-sm text-charcoal/80 space-y-2">
          {units && (
            <div class="flex justify-between">
              <span class="text-charcoal/60">Units</span>
              <span class="font-medium">{units}</span>
            </div>
          )}
          {summary && <p class="text-charcoal/70 leading-relaxed">{summary}</p>}
        </div>
      )
    }
  </div>
</Tag>
