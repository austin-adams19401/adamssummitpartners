---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import SectionHeading from '~/components/SectionHeading.astro';
import CTABanner from '~/components/CTABanner.astro';

const assetClasses = [
  {
    title: 'Apartment Communities',
    body: 'Our primary focus. Class A and Class B multifamily in Mountain West submarkets where rent, wages, and job growth actually support the underwriting.',
  },
  {
    title: 'Small Residential Communities',
    body: 'Selective acquisitions of smaller multifamily properties where a hands-on operator can lift net operating income without gimmicks.',
  },
];

const process = [
  {
    n: '01',
    title: 'Sourcing',
    body: 'Direct relationships with brokers, sellers, and operators in the submarkets we actually know. Not a deal-of-the-week email list.',
  },
  {
    n: '02',
    title: 'Underwriting',
    body: 'We walk every property. We stress rent, vacancy, expenses, and exit caps. If the numbers only work on aggressive cases, we pass.',
  },
  {
    n: '03',
    title: 'Capitalization',
    body: 'Match debt to the asset. We do not force-fit capital structures that look clever on paper and fail in a downturn.',
  },
  {
    n: '04',
    title: 'Operations',
    body: 'Every property gets a qualified manager and a written system. Austin builds the systems, holds the standards, and walks the buildings.',
  },
  {
    n: '05',
    title: 'Reporting',
    body: 'Monthly written update, quarterly summary, and a live dashboard built in-house. Bad news first, always. Investors hear from the operator.',
  },
  {
    n: '06',
    title: 'Exit',
    body: 'We sell when the market rewards the work, not on an arbitrary timer. Holds typically run 5 to 10 years.',
  },
];
---

<BaseLayout
  title="Approach"
  description="How Adams Summit Partners underwrites, operates, and reports on multifamily real estate investments in the Mountain West."
>
  <PageHero
    eyebrow="Investment Approach"
    heading="Discipline is the strategy."
    lede="The durable returns in real estate come from buying well, operating patiently, and staying honest about what the numbers actually say. That is the whole approach."
  />

  <section class="bg-white py-20 md:py-28">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="Thesis"
        heading="Mountain West multifamily, with conviction."
        lede="Population growth, wage growth, and housing supply pressure across the Mountain West keep demand for well-run apartment communities durable. We invest where a good operator can still buy at a reasonable basis and run the property well."
      />
    </div>
  </section>

  <section class="bg-cream py-20 md:py-28">
    <div class="container-narrow">
      <SectionHeading eyebrow="Asset Classes" heading="What we acquire." />

      <div class="grid gap-8 md:grid-cols-2 mt-16">
        {
          assetClasses.map(({ title, body }) => (
            <div class="bg-white p-8 md:p-10 border-t-2 border-gold">
              <h3 class="font-serif text-2xl text-navy mb-3">{title}</h3>
              <p class="text-charcoal/80 leading-relaxed">{body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white py-20 md:py-28">
    <div class="container-narrow">
      <SectionHeading eyebrow="The Process" heading="From first look to final exit." />

      <ol class="grid gap-10 md:grid-cols-2 mt-16">
        {
          process.map(({ n, title, body }) => (
            <li class="flex gap-6">
              <span class="font-serif text-gold text-3xl md:text-4xl shrink-0 w-16">{n}</span>
              <div>
                <h3 class="font-serif text-2xl text-navy mb-2">{title}</h3>
                <p class="text-charcoal/80 leading-relaxed">{body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <CTABanner
    heading="Ready to talk about a partnership?"
    body="We share current and upcoming multifamily opportunities with qualified accredited investors. Tell us what you are looking for and we will follow up."
  />
</BaseLayout>
