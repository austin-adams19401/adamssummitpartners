---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import SectionHeading from '~/components/SectionHeading.astro';
import TeamMember from '~/components/TeamMember.astro';
import CTABanner from '~/components/CTABanner.astro';

const teamAll = await getCollection('team');
const team = teamAll.sort((a, b) => a.data.order - b.data.order);

const values = [
  {
    title: 'Family is the point',
    body: 'The business funds a life. It does not replace one. That shapes how we size deals, how long we hold, and how many we run at once.',
  },
  {
    title: 'Operations over optics',
    body: 'Most syndicators are good at raising money and bad at running properties. We built this firm to be the opposite.',
  },
  {
    title: 'Fairness to everyone at the table',
    body: 'Investors, residents, staff, and contractors all deserve honest numbers and honest work. If a deal only wins for one side, it is not our deal.',
  },
  {
    title: 'Thinking in generations',
    body: 'We buy properties we would be fine owning through a full cycle. Holds are deliberate. Distributions are predictable.',
  },
  {
    title: 'Intentional work',
    body: 'Thirty focused hours on the right things beats sixty reactive hours on everything. We protect calendar space for walking properties and thinking through decisions.',
  },
  {
    title: 'Generosity with purpose',
    body: 'A meaningful portion of firm profits goes to the foster system, parents of young children, and families of kids with disabilities.',
  },
];
---

<BaseLayout
  title="About"
  description="Adams Summit Partners is a Utah multifamily real estate firm founded by Austin Adams. Operator-first, built for working investors across the Mountain West."
>
  <PageHero
    eyebrow="Our Firm"
    heading="A small firm run by the operator."
    lede="Adams Summit Partners is a Utah-based real estate firm. We acquire multifamily properties across the Mountain West and run them ourselves, for working investors who want a real operator on the other end of their capital."
  />

  <section class="bg-white py-20 md:py-28">
    <div class="container-prose prose-brand text-lg">
      <p>
        Austin Adams founded the firm. He is a software engineer by training, lives in
        Kaysville, Utah with his wife Janae and their nine kids, and built Adams Summit
        Partners because he watched too much of multifamily syndication get dominated by
        people who raise well and run poorly. He wanted the opposite of that. Systems
        first, marketing second.
      </p>
      <p>
        The focus is narrow on purpose: multifamily properties in the Mountain West. The
        investors are working professionals, small business owners, and people with real
        savings they want put to work by someone who actually answers the phone. Not
        institutions. Not anonymous LPs. Partners.
      </p>
      <p>
        Residents matter as much as investors. A property only works long-term if it is the
        best-run and most-responsive option in its market at a rent a working family can
        actually afford. That is not a marketing line. It is a constraint we underwrite to.
      </p>
      <p>
        A meaningful portion of firm profits goes back to causes the family cares about:
        the foster system, parents of young children, and families of kids with
        disabilities. Business funds the life, including the giving.
      </p>
    </div>
  </section>

  <section class="bg-cream py-20 md:py-28">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="Our Values"
        heading="How we show up on every deal."
        align="center"
      />

      <div class="grid gap-8 md:grid-cols-3 mt-16">
        {
          values.map(({ title, body }) => (
            <div class="text-center">
              <span class="gold-rule mx-auto mb-6" />
              <h3 class="font-serif text-2xl text-navy mb-3">{title}</h3>
              <p class="text-charcoal/80 leading-relaxed">{body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white py-20 md:py-28">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="Leadership"
        heading="The founder."
        align="center"
      />

      <div class="grid gap-12 md:gap-16 md:grid-cols-1 max-w-xl mx-auto mt-16">
        {
          team.map((member) => (
            <TeamMember
              name={member.data.name}
              role={member.data.role}
              bio={member.data.bio}
              photo={member.data.photo}
            />
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner
    heading="Want to talk?"
    body="If you have capital looking for a real operator, start a conversation. No pitch deck, no pressure."
  />
</BaseLayout>
