---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import TagChip from '~/components/TagChip.astro';
import ReadingTime from '~/components/ReadingTime.astro';
import CTABanner from '~/components/CTABanner.astro';
import { computeReadingTime } from '~/lib/readingTime';

const austin = await getEntry('team', 'principal-1');

const postsAll = await getCollection(
  'blog',
  ({ data }) => !data.draft && data.author === 'Austin Adams',
);
const posts = postsAll.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (d) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const postsWithReadingTime = await Promise.all(
  posts.map(async (post) => ({ post, stats: computeReadingTime(post.body) })),
);
---

<BaseLayout
  title="Austin Adams | Insights"
  description="Posts by Austin Adams, founder of Adams Summit Partners. Notes on Mountain West multifamily, underwriting, and operating."
>
  <PageHero
    eyebrow="Author"
    heading={austin?.data.name ?? 'Austin Adams'}
    lede={austin?.data.bio ??
      'Founder of Adams Summit Partners. Writes about Mountain West multifamily and running properties well.'}
  />

  <section class="bg-cream py-20 md:py-28">
    <div class="container-narrow">
      <div class="mb-10 flex items-center justify-between">
        <h2 class="font-serif text-3xl text-navy">Published posts.</h2>
        <a
          href="/blog/"
          class="text-sm tracking-wider uppercase font-medium text-navy hover:text-gold border-b border-gold pb-1"
        >
          All Insights →
        </a>
      </div>

      {
        postsWithReadingTime.length === 0 ? (
          <p class="text-charcoal/70">No posts published yet.</p>
        ) : (
          <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
            {postsWithReadingTime.map(({ post, stats }) => (
              <a
                href={`/blog/${post.slug}/`}
                class="group block bg-white overflow-hidden shadow-sm hover:shadow-xl transition-shadow"
              >
                {post.data.image && (
                  <div class="aspect-[16/9] overflow-hidden">
                    <img
                      src={post.data.image}
                      alt=""
                      loading="lazy"
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                  </div>
                )}
                <div class="p-7">
                  <div class="flex items-center gap-3 mb-3">
                    <p class="eyebrow">{formatDate(post.data.pubDate)}</p>
                    <span class="text-charcoal/30">·</span>
                    <ReadingTime minutes={stats.minutes} />
                  </div>
                  <h3 class="font-serif text-2xl text-navy mb-2 group-hover:text-gold transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-charcoal/70 leading-relaxed">
                    {post.data.description}
                  </p>
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-4">
                      {post.data.tags.map((t) => (
                        <TagChip tag={t} />
                      ))}
                    </div>
                  )}
                </div>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <CTABanner />
</BaseLayout>
