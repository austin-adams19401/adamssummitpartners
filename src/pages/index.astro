---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import SectionHeading from '~/components/SectionHeading.astro';
import StatBlock from '~/components/StatBlock.astro';
import DealCard from '~/components/DealCard.astro';
import TeamMember from '~/components/TeamMember.astro';
import CTABanner from '~/components/CTABanner.astro';

const dealsAll = await getCollection('deals');
const deals = dealsAll
  .filter((d) => d.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const teamAll = await getCollection('team');
const team = teamAll.sort((a, b) => a.data.order - b.data.order);

const values = [
  {
    title: 'Operations over optics',
    body: 'Most syndicators are good at raising money and bad at running properties. We built this firm to be the opposite. Systems first, marketing second.',
  },
  {
    title: 'Fairness to everyone at the table',
    body: 'Investor returns matter. So does a rent a working family can actually afford. A good deal works for both, or it is not a good deal.',
  },
  {
    title: 'Thinking in generations',
    body: 'Holds are 5 to 10 years on purpose. We do not force exits to hit arbitrary deadlines, and we do not buy things we would be nervous to own through a downturn.',
  },
  {
    title: 'Family is the point',
    body: 'The business funds a life. It does not replace one. That shapes how we size deals, how long we hold, and how many we run at a time.',
  },
];
---

<BaseLayout
  title="Adams Summit Partners"
  description="Mountain West multifamily real estate syndication based in Utah. Built for working investors who want the operator to pick up the phone."
  transparentHeader={true}
>
  <Hero />

  <!-- Why ASP -->
  <section class="bg-cream py-20 md:py-28">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="Why Adams Summit"
        heading="A Partner, Not a Platform."
        lede="We run a small, focused real estate firm. Our investors are partners who know the operator by name and know how their properties are actually being run."
      />

      <div class="grid gap-8 md:grid-cols-2 mt-16">
        {
          values.map(({ title, body }) => (
            <div class="bg-white p-8 md:p-10 border-l-2 border-gold">
              <h3 class="font-serif text-2xl text-navy mb-3">{title}</h3>
              <p class="text-charcoal/80 leading-relaxed">{body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Approach teaser -->
  <section class="bg-white py-20 md:py-28">
    <div class="container-narrow grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <div class="relative aspect-[4/5] overflow-hidden bg-navy">
        <img
          src="https://images.unsplash.com/photo-1449844908441-8829872d2607?auto=format&fit=crop&w=1600&q=60"
          alt="Mountain West multifamily property"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <div>
        <SectionHeading
          eyebrow="Our Approach"
          heading="Built to operate, not just raise."
          lede="We acquire multifamily properties across the Mountain West for working professionals and small business owners who want a real operator on the other end of their capital."
        />
        <div class="mt-8 space-y-4 prose-brand max-w-none">
          <p>
            Every property gets a qualified manager and a system that runs it. We stress the
            numbers against a real downside, we walk the buildings, and we pass when the deal
            only works on aggressive cases. When something goes wrong, investors hear from
            the operator first, not a PR statement.
          </p>
        </div>
        <a href="/approach" class="btn-outline mt-10 text-navy border-navy hover:bg-navy hover:text-gold">
          See How We Operate
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Deals -->
  <section class="bg-cream py-20 md:py-28">
    <div class="container-narrow">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
        <SectionHeading
          eyebrow="What We Pursue"
          heading="The kinds of properties we are built to run."
        />
        <a href="/portfolio" class="text-sm tracking-wider uppercase font-medium text-navy hover:text-gold border-b border-gold pb-1 self-start md:self-end">
          View Full Portfolio →
        </a>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {
          deals.map((deal) => (
            <DealCard
              name={deal.data.name}
              location={deal.data.location}
              assetClass={deal.data.assetClass}
              units={deal.data.units}
              status={deal.data.status}
              image={deal.data.heroImage}
              summary={deal.data.summary}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Stat strip -->
  <section class="bg-navy py-20 md:py-24">
    <div class="container-narrow">
      <StatBlock
        invert={true}
        stats={[
          { value: 'Mtn West', label: 'Regional Focus' },
          { value: 'Multifamily', label: 'Property Type' },
          { value: '5 to 10 yr', label: 'Target Hold' },
          { value: '100%', label: 'Principal Co-Invest' },
        ]}
      />
    </div>
  </section>

  <!-- Team teaser -->
  <section class="bg-white py-20 md:py-28">
    <div class="container-narrow">
      <SectionHeading
        eyebrow="Leadership"
        heading="The person behind the partnership."
        lede="Small and intentional. The people running the firm are the same people answering your calls and walking the properties."
        align="center"
      />

      <div class="grid gap-10 md:gap-16 md:grid-cols-1 max-w-xl mx-auto mt-16">
        {
          team.map((member) => (
            <TeamMember
              name={member.data.name}
              role={member.data.role}
              bio={member.data.bio}
              photo={member.data.photo}
            />
          ))
        }
      </div>

      <div class="text-center mt-16">
        <a href="/about" class="btn-outline text-navy border-navy hover:bg-navy hover:text-gold">
          Meet the Firm
        </a>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
