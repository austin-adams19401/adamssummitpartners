---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import DealCard from '~/components/DealCard.astro';
import CTABanner from '~/components/CTABanner.astro';

const dealsAll = await getCollection('deals');
const deals = dealsAll.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Portfolio"
  description="The kinds of Mountain West multifamily properties Adams Summit Partners targets. Current offerings shared privately with accredited investors."
>
  <PageHero
    eyebrow="Portfolio"
    heading="The kinds of properties we pursue."
    lede="No track record to show yet. These are representative samples of the Mountain West multifamily we are built to acquire and operate. Current and upcoming offerings are shared privately with accredited investors on our list."
  />

  <section class="bg-cream py-20 md:py-28">
    <div class="container-narrow">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          deals.map((deal) => (
            <DealCard
              name={deal.data.name}
              location={deal.data.location}
              assetClass={deal.data.assetClass}
              units={deal.data.units}
              status={deal.data.status}
              image={deal.data.heroImage}
              summary={deal.data.summary}
            />
          ))
        }
      </div>

      <div class="mt-20 max-w-2xl mx-auto text-center">
        <p class="eyebrow mb-4">A Note on Disclosure</p>
        <p class="text-charcoal/80 leading-relaxed">
          The properties shown are representative samples, not live offerings. Specific
          offering details, including projected returns, are shared through our offering
          documents with accredited investors on our list.
          <a href="/disclosures" class="underline text-navy hover:text-gold">
            Read full disclosures
          </a>.
        </p>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Want to be on the short list when we have a deal?"
    body="Accredited investors on our list hear first when an offering opens. Tell us a little about what you are looking for and we will follow up."
    ctaLabel="Request Access"
  />
</BaseLayout>
